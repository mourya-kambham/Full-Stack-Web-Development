<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-4">
        <h3>Listing Details</h3>
        </div>
        <div class="card col-6 offset-4 show-card">
            <div class="card" style="width: 18rem;">
                <img src="<%= listing.image.url%>" class="card-img-top show-img" alt="image">
                <br>
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b><br>
                        <%= listing.description %><br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %><br>
                        <%= listing.location %><br>
                        <%= listing.country %>
                    </p>
                </div>
            </div>
        </div>
        <br>
    </div>
    <div class="btns">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-4 edit-btn">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-dark offset-6">Delete</button>
        </form>
    </div>
    <br>
</body>
